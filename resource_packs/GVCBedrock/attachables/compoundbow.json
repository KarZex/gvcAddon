{
    "format_version": "1.16.100",
    "minecraft:attachable": {
        "description": {
            "identifier": "gun:compoundbow",
            "materials": {
                "default": "iron_golem",
                "enchanted": "armor_enchanted",
                "scope": "entity_alphablend"
            },
            "textures": {
                "default": "textures/models/compoundbow.png",
                "none": "textures/models/leemk4.png",
                "scope6x_scope": "textures/models/scope2.png",
                "scope2x": "textures/models/leemk4.png",
                "coyote": "textures/models/coyote.png",
                "scope2x_scope": "textures/models/scope.png",
                "enchanted": "textures/misc/enchanted_item_glint"
            },
            "geometry": {
                "default": "geometry.compoundbow",
                "none": "geometry.sniperscope",
                "scope6x": "geometry.scope6x",
                "scope": "geometry.scope",
                "scope2x": "geometry.scope2x",
                "acog": "geometry.acog",
                "coyote": "geometry.coyote",
                "horo": "geometry.horo",
                "suppressor": "geometry.suppressor",
                "grip": "geometry.grip",
                "lasersight": "geometry.lasersight",
                "gripod": "geometry.gripod",
                "bipod": "geometry.bipod",
                "anglegrip": "geometry.anglegrip",
                "dotsight": "geometry.dotsight"
            },
            "animations": {
                "first": "animation.ak47.first2",
                "ads": "animation.ak47.ads3",
                "third": "animation.item.third2",
                "ads_scope": "animation.mosin.ads",
                "ads_sight": "animation.sight.ads"
            },
            "scripts": {
                "pre_animation": [
                    "v.main_hand = c.item_slot == 'main_hand';"
                ],
                "animate": [
                    {
                        "first": "(v.main_hand && c.is_first_person) && !query.is_sneaking"
                    },
                    {
                        "ads_sight": "(v.main_hand && c.is_first_person) && query.is_sneaking"
                    },
                    {
                        "third": "v.main_hand && !c.is_first_person"
                    },
                    {
                        "ads_scope": "query.property('zex:is_scoping') && (v.main_hand && c.is_first_person) && query.is_sneaking"
                    }
                ]
            },
            "render_controllers": [
                {
                    "controller.render.armor": "query.is_item_name_any('slot.weapon.mainhand', 0, 'gun:compoundbow')"
                },
                {
                    "controller.render.sights": "query.property('zex:sights') != 0 && v.main_hand && ((!query.property('zex:is_scoping') || !c.is_first_person))"
                }
            ]
        }
    }
}